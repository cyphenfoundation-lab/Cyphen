import os
import time
from pathlib import Path
from google import genai
from google.genai import types

def upload_media_batch(source_dir: str, supported_extensions: list = None) -> list:
    """
    Scans a local directory, uploads all matched media files to the Gemini Files API,
    and blocks until processing is complete so they are immediately usable.
    
    Args:
        source_dir (str): Path to the folder containing your social media media.
        supported_extensions (list): List of extensions to look for. Defaults to common media.
        
    Returns:
        list: A list of active Gemini File objects ready to be passed to the model.
    """
    # Initialize the unified Gemini client
    client = genai.Client()
    
    if supported_extensions is None:
        supported_extensions = ['.mp4', '.mov', '.mp3', '.wav', '.png', '.jpg', '.jpeg', '.pdf']
        
    path_dir = Path(source_dir)
    if not path_dir.exists() or not path_dir.is_dir():
        raise FileNotFoundError(f"The specified directory does not exist: {source_dir}")

    # Discover target files in the folder
    files_to_upload = [p for p in path_dir.iterdir() if p.suffix.lower() in supported_extensions]
    
    if not files_to_upload:
        print(f"No matching files found in '{source_dir}' with extensions {supported_extensions}")
        return []

    print(f"🚀 Found {len(files_to_upload)} files to upload. Starting batch process...\n")
    active_file_objects = []

    for file_path in files_to_upload:
        print(f"📁 Processing: '{file_path.name}' ({round(file_path.stat().st_size / (1024*1024), 2)} MB)")
        
        try:
            # 1. Upload file via the modern SDK
            uploaded_file = client.files.upload(file=str(file_path))
            print(f"   ↳ Upload complete. Assigned ID: {uploaded_file.name}")
            
            # 2. Poll for file readiness (Critical for video assets)
            file_info = client.files.get(name=uploaded_file.name)
            
            # Check if the platform returned a 'state' attribute (common for video handling)
            while getattr(file_info, 'state', None) == "PROCESSING":
                print(f"   ⏳ File is processing on Google servers... Retrying in 5 seconds.")
                time.sleep(5)
                file_info = client.files.get(name=uploaded_file.name)
                
            if getattr(file_info, 'state', None) == "FAILED":
                print(f"   ❌ Server processing failed for {file_path.name}. Skipping asset.")
                continue

            print(f"   ✅ Asset is ACTIVE and ready. URI: {file_info.uri}\n")
            active_file_objects.append(file_info)
            
        except Exception as e:
            print(f"   ❌ Error uploading {file_path.name}: {e}\n")

    print(f"🎉 Batch complete. Successfully staged {len(active_file_objects)} / {len(files_to_upload)} assets.")
    return active_file_objects

# =====================================================================
# Execution Pipeline Example
# =====================================================================
if __name__ == "__main__":
    # Create a dummy test directory and file for immediate testing if desired
    # Replace 'my_social_assets' with your actual media storage directory path
    MEDIA_DIRECTORY = "./my_social_assets"
    os.makedirs(MEDIA_DIRECTORY, exist_ok=True)
    
    # 1. Upload all media files from your staging folder
    uploaded_assets = upload_media_batch(source_dir=MEDIA_DIRECTORY)
    
    # 2. Inject the entire file collection directly into your content model prompt
    if uploaded_assets:
        print("\n🤖 Forwarding assets to Gemini 3.1 Pro for platform generation...")
        
        # Build your prompt contents dynamically, grouping all media blocks
        prompt_contents = []
        prompt_contents.extend(uploaded_assets) # Inject the active file references
        prompt_contents.append("Review these reference files and generate the structured content assets matching our configuration guidelines for TikTok and YouTube Shorts.")
        
        # Execute Generation
        client = genai.Client()
        response = client.models.generate_content(
            model="gemini-3.1-pro",
            contents=prompt_contents,
            # (Optional): Append your specific response_schema configuration here
        )
        
        print("\n--- Model Response ---")
        print(response.text)
